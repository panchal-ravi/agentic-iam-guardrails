      "description": "Counter increments once per /evaluate call where any of {prompt_safety_risk, jailbreak, harm, hap, unethical_behavior} > 0.5. Click to show matching logs.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "targets": [
        { "refId": "A", "expr": "sum(wxgov_violations_total)", "instant": true, "legendFormat": "Total" },
        { "refId": "B", "expr": "sum(rate(wxgov_violations_total[5m]))", "instant": true, "legendFormat": "Rate /s" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] },
          "unit": "short",
          "links": [
            {
              "title": "Filter logs — wx-gov violations (any metric > 0.5)",
              "url": "/d/${__dashboard.uid}?${__url_time_range}&var-loki_expr=%7Bservice_name%3D%22wx-gov-api%22%7D%20%7C%3D%20%22guardrails.metrics.completed%22%20%7C%20json%20%7C%20json%20harm%3D%22response.harm%22%2C%20hap%3D%22response.hap%22%2C%20unethical%3D%22response.unethical_behavior%22%2C%20prompt_safety_risk%3D%22response.prompt_safety_risk%22%2C%20jailbreak%3D%22response.jailbreak%22%20%7C%20harm%20%3E%200.5%20or%20hap%20%3E%200.5%20or%20unethical%20%3E%200.5%20or%20prompt_safety_risk%20%3E%200.5%20or%20jailbreak%20%3E%200.5%20%7C%20line_format%20%22%7B%7B.request_id%7D%7D%20%20%7B%7B.service_name%7D%7D%20%20%7B%7B.event%7D%7D%20%20%7B%7B.message%7D%7D%22",
              "targetBlank": false
            }
          ]
        },
        "overrides": []
