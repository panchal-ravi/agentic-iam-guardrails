{
  "name": "web-app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.18"
  },
  "scripts": {
    "clean": "rm -rf .next .swc .turbo node_modules/.cache tsconfig.tsbuildinfo",
    "dev": "next dev -p 8501 -H 0.0.0.0",
    "dev:clean": "npm run clean && next dev -p 8501 -H 0.0.0.0",
    "build": "next build",
    "start": "next start -p 8501 -H 0.0.0.0",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "format": "prettier --write \"src/**/*.{ts,tsx,scss}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,scss}\""
  },
  "dependencies": {
    "@carbon/icons-react": "11.65.0",
    "@carbon/react": "1.92.0",
    "@carbon/styles": "1.91.0",
    "iron-session": "8.0.4",
    "jose": "5.9.6",
    "next": "15.5.15",
    "pino": "9.6.0",
    "pino-pretty": "13.0.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-markdown": "9.0.3",
    "remark-gfm": "4.0.0",
    "sass": "1.85.0",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@testing-library/dom": "10.4.0",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@types/node": "20.17.10",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "@typescript-eslint/eslint-plugin": "8.18.0",
    "@typescript-eslint/parser": "8.18.0",
    "@vitejs/plugin-react": "4.3.4",
    "@vitest/coverage-v8": "2.1.9",
    "vite": "5.4.21",
    "autoprefixer": "10.4.20",
    "eslint": "9.39.4",
    "eslint-config-next": "15.5.15",
    "jsdom": "25.0.1",
    "msw": "2.7.0",
    "postcss": "8.4.49",
    "prettier": "3.4.2",
    "typescript": "5.7.2",
    "vitest": "2.1.9"
  }
}
